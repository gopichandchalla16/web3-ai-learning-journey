# .env.example — copy this to .env and fill in your real keys
# NEVER commit your real .env file to GitHub!

# Get from: alchemy.com → Create App → Ethereum Sepolia → API Key
ALCHEMY_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY_HERE

# Get from: console.groq.com (free)
GROQ_API_KEY=YOUR_GROQ_KEY_HERE

# Get from: platform.openai.com (optional, paid)
OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE
